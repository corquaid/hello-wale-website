---
import { Image } from "astro:assets";
import companiesDoor from "../assets/images/companies-door.jpg";
import benefitIcon from "../assets/images/benefit-icon.png";

const benefits = [
	"Lower cost than you think",
	"Employer branding",
	"Higher creativity",
	"Better retention",
];
---

<section class="bg-white">
	<div class="flex flex-col lg:flex-row">
		<div class="relative h-90 shrink-0 sm:h-120 lg:h-auto lg:w-[49%]">
			<Image
				src={companiesDoor}
				alt="A hotel-style door hanger reading 'Where work doesn't feel like work anymore' on a dark wood door surrounded by jungle greenery"
				class="absolute inset-0 h-full w-full object-cover"
				widths={[640, 960, 1400, 2048]}
				sizes="(min-width: 1024px) 60vw, 100vw"
			/>
		</div>

		<div class="flex flex-1 flex-col items-start justify-center gap-8 px-6 py-16 sm:px-10 lg:px-20 lg:py-24">
			<div class="flex flex-col items-start gap-6">
				<p
					class="text-wale-700 font-display text-[11px] tracking-[0.33px] uppercase"
				>
					For Companies
				</p>

				<div class="flex flex-col gap-4">
					<h2 class="font-display text-3xl leading-tight tracking-[-0.66px] text-black sm:text-4xl lg:text-[44px] lg:leading-13.5">
						The wellbeing benefit
						<br />
						your team will actually use.
					</h2>
					<p class="max-w-md font-display text-[17px] leading-7 text-[#5f5f5f]">
						Workation isn't a perk anymore — it's how the best teams stay sharp, creative,
						and retained. HelloWale makes it simple to offer.
					</p>
				</div>

				<div class="grid w-full max-w-xl grid-cols-1 gap-4 sm:grid-cols-2">
					{
						benefits.map((benefit) => (
							<div class="flex items-center gap-2 rounded-xl bg-[#fff3e7] px-5 py-4">
								<img src={benefitIcon.src} alt="" class="h-8 w-8 shrink-0 object-contain" />
								<p class="font-display text-base font-medium text-wale-700">{benefit}</p>
							</div>
						))
					}
				</div>
			</div>

			<a
				href={`${import.meta.env.BASE_URL}contact`}
				class="rounded-bl-xl rounded-tl-xl rounded-tr-xl bg-wale-700 px-6 py-3.5 font-display text-sm font-medium tracking-[0.14px] text-white"
			>
				Partner your company
			</a>
		</div>
	</div>
</section>
