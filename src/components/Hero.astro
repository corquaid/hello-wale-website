---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import heroBg from "../assets/images/hero-bg.jpg";
import officeBubble from "../assets/images/office-bubble.svg";
import Nav from "./Nav.astro";
import CtaButton from "./CtaButton.astro";
import type { Locale } from "../i18n/utils";

interface Cta {
	label: string;
	href?: string;
	variant: "ghost" | "cream" | "maroon" | "peach";
}

interface Props {
	beforeText?: string;
	bubbleText?: string;
	afterText?: string;
	subtext?: string;
	ctas?: [Cta, Cta];
	showCtas?: boolean;
	showPhoto?: boolean;
	photo?: ImageMetadata;
	navVariant?: "solid" | "transparent";
	navLogoVariant?: "secondary" | "primary";
	navTextVariant?: "light" | "dark";
	bubbleWidthClass?: string;
	align?: "center" | "left";
	lang?: Locale;
	currentPath?: string;
}

const {
	beforeText = "Your",
	bubbleText = "office,",
	afterText = "reimagined.",
	subtext = "We're building the platform for remote work stays. Not just a place to sleep — a place where things actually happen. Be one of the first.",
	ctas = [
		{ label: "Partner with us", variant: "ghost" },
		{ label: "Start Listing — It's Free", variant: "cream" },
	],
	showCtas = true,
	showPhoto = true,
	photo = heroBg,
	navVariant = "transparent",
	navLogoVariant = "secondary",
	navTextVariant = "light",
	bubbleWidthClass = "w-[3.5em]",
	align = "center",
	lang = "en",
	currentPath = "",
} = Astro.props;
---

<section
	class="relative flex min-h-[85vh] flex-col overflow-hidden px-6 pb-16 sm:px-10 sm:pb-24 lg:min-h-[85vh] lg:px-20 lg:pb-32"
	style="background-image: linear-gradient(155deg, #fadec2 1.5%, #d19161 34%, #3d142b 100%);"
>
	{
		showPhoto && (
			<div class="absolute inset-0" aria-hidden="true">
				<Image
					src={photo}
					alt=""
					class="h-full w-full object-cover"
					widths={[640, 1024, 1512, 2048]}
					sizes="100vw"
					loading="eager"
					fetchpriority="high"
				/>
				<div class="absolute inset-0 bg-black/25" />
			</div>
		)
	}

	<div class="relative w-full">
		<Nav
			variant={navVariant}
			logoVariant={navLogoVariant}
			textVariant={navTextVariant}
			lang={lang}
			currentPath={currentPath}
		/>
	</div>

	<div
		class:list={[
			"relative flex flex-1 flex-col justify-center gap-8",
			align === "left" ? "items-start text-left" : "items-center text-center",
		]}
	>
		<h1 class="relative isolate font-display text-5xl font-bold leading-[1.02] text-white sm:text-6xl lg:text-7xl">
			{beforeText} <span class="relative isolate -z-10">
				<img
					src={officeBubble.src}
					alt=""
					aria-hidden="true"
					class:list={[
						"absolute left-1/2 top-1/2 -z-10 h-[1.8em] max-w-none -translate-x-1/2 -translate-y-2/5",
						bubbleWidthClass,
					]}
				/>
				<span class="relative text-wale-peach">{bubbleText}</span>
			</span> {afterText}
		</h1>

		<p class="max-w-xl font-display text-lg leading-[1.7] text-white">
			{subtext}
		</p>

		{
			showCtas && (
				<div class="flex w-full max-w-md flex-col gap-2 sm:flex-row">
					<CtaButton
						label={ctas[0].label}
						href={ctas[0].href}
						variant={ctas[0].variant}
						shape="full"
						radius="2xl"
						class="flex-1"
					/>
					<CtaButton
						label={ctas[1].label}
						href={ctas[1].href}
						variant={ctas[1].variant}
						shape="notch"
						radius="2xl"
						class="flex-1"
					/>
				</div>
			)
		}
	</div>
</section>
