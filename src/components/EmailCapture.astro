---
import { Image } from "astro:assets";
import gallery162 from "../assets/images/gallery-162.jpg";
import gallery164 from "../assets/images/gallery-164.jpg";
import gallery165 from "../assets/images/gallery-165.jpg";
import gallery166 from "../assets/images/gallery-166.jpg";
import gallery167 from "../assets/images/gallery-167.jpg";
import gallery168 from "../assets/images/gallery-168.jpg";
import gallery169 from "../assets/images/gallery-169.jpg";
import gallery170 from "../assets/images/gallery-170.jpg";
import gallery171 from "../assets/images/gallery-171.jpg";
import gallery172 from "../assets/images/gallery-172.jpg";

// 6 columns of 2 photos each. Built as explicit flex columns (not CSS
// `columns-*`) because multi-column's default balance algorithm actively
// re-distributes items to equalize column height, which fights the
// staggered margin below and silently un-staggers it.
const columns = [
	[gallery168, gallery167],
	[gallery169, gallery166],
	[gallery172, gallery162],
	[gallery164, gallery171],
	[gallery170, gallery165],
	[gallery172, gallery168],
];

const listing = {
	name: "Glass Tower Retreat",
	location: "Warsaw, Poland",
	rating: "4.89",
};
---

<section class="relative isolate flex min-h-200 flex-col justify-start overflow-hidden bg-linear-to-b from-[#914d61] to-[#380121] px-6 py-20 sm:min-h-237.5 sm:px-10 lg:min-h-287.5 lg:px-20 lg:py-30">
	<div class="absolute inset-x-0 bottom-0 -z-20 flex items-end gap-3 opacity-70 lg:gap-4">
		{
			columns.map((photos, colIndex) => (
				<div
					class:list={[
						"flex flex-1 flex-col gap-3 lg:gap-4",
						colIndex % 2 === 1 && "translate-y-[25%]",
						colIndex >= 4 && "hidden lg:flex",
						colIndex === 3 && "hidden sm:flex",
					]}
				>
					{photos.map((photo) => (
						<div class="aspect-239/308 overflow-hidden rounded-2xl">
							<Image
								src={photo}
								alt=""
								class="h-full w-full rounded-2xl object-cover"
								widths={[200, 320, 480]}
								sizes="(min-width: 1024px) 16vw, 33vw"
								loading="lazy"
							/>
						</div>
					))}
				</div>
			))
		}
	</div>

	<div class="absolute inset-0 -z-10 bg-linear-to-b from-transparent from-70% via-[#380121]/70 via-90% to-[#380121]"></div>

	<div class="relative mx-auto flex max-w-3xl flex-col items-center gap-8 text-center">
		<p class="font-display text-[11px] font-semibold tracking-[0.33px] text-wale-peach uppercase">
			For remote workers &amp; freelancers
		</p>
		<p class="font-display text-3xl leading-tight font-bold tracking-[-0.6px] text-white sm:text-4xl lg:text-[40px] lg:leading-12.5">
			Solo traveler? Be the first to know
		</p>
		<p class="max-w-xl font-display text-[17px] leading-7 text-[#eaeaea]">
			Workation isn't just for companies. If you're a freelancer or remote worker, leave
			your email and we'll let you know the moment HelloWale opens to individuals.
		</p>

		<form
			class="flex w-full max-w-md flex-col gap-2 sm:flex-row"
			data-email-capture
		>
			<input
				type="email"
				required
				placeholder="Enter your email address"
				aria-label="Email address"
				class="h-15 rounded-2xl border border-wale-peach bg-wale-peach/16 px-6 font-display text-sm text-white placeholder:text-white/70 focus:outline-none sm:flex-1"
			/>
			<button
				type="submit"
				aria-label="Submit"
				class="flex h-15 w-full shrink-0 items-center justify-center rounded-bl-2xl rounded-tl-2xl rounded-tr-2xl bg-wale-cream sm:w-14.75"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 24 24"
					fill="none"
					stroke="#511A3B"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					class="h-4 w-4"
				>
					<path d="M5 12h14M13 6l6 6-6 6" />
				</svg>
			</button>
		</form>
		<p class="hidden font-display text-sm text-wale-peach" data-email-success>
			Thanks — we'll be in touch when it's your turn.
		</p>
	</div>
</section>

<script>
	document.querySelectorAll<HTMLFormElement>("[data-email-capture]").forEach((form) => {
		form.addEventListener("submit", (e) => {
			e.preventDefault();
			const success = form.parentElement?.querySelector<HTMLElement>("[data-email-success]");
			form.classList.add("hidden");
			success?.classList.remove("hidden");
		});
	});
</script>
