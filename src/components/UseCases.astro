---
import { Image } from "astro:assets";
import usecaseMarketing from "../assets/images/usecase-marketing.jpg";
import usecaseTechteam from "../assets/images/usecase-techteam.jpg";

const defaultUseCases = [
	{
		company: "Marketing agency",
		badge: "25 employees",
		description: "Quarterly team workations to reset and brainstorm next campaigns.",
		outcome: "Three campaigns. One villa in Tuscany. Zero meeting fatigue.",
		image: usecaseMarketing,
		imageAlt: "Two colleagues from a marketing agency looking at a laptop together outdoors",
		reverse: false,
	},
	{
		company: "Tech scale-up",
		badge: "25 employees",
		description:
			"Each team member gets 2 workation weeks per year as part of their wellbeing package.",
		outcome: "A retention story we tell at every job interview.",
		image: usecaseTechteam,
		imageAlt: "A tech team collaborating around a table with coffee and notes",
		reverse: true,
	},
];

interface Props {
	eyebrow?: string;
	headline?: string;
	subtext?: string;
	useCases?: typeof defaultUseCases;
}

const {
	eyebrow = "Real teams. Real workations.",
	headline = "Built for teams of every size.",
	subtext = "Three approaches to workation. One platform that makes it work.",
	useCases = defaultUseCases,
} = Astro.props;
---

<section class="bg-white px-6 py-20 sm:px-10 lg:px-20 lg:py-30">
	<div class="mx-auto flex max-w-6xl flex-col items-center gap-16">
		<div class="flex flex-col items-center gap-4 text-center">
			<p
				class="bg-[linear-gradient(176deg,#fadec2_1.5%,#d19161_34%,#3d142b_100%)] bg-clip-text font-display text-[11px] tracking-[0.33px] text-transparent uppercase"
			>
				{eyebrow}
			</p>
			<p class="max-w-3xl font-display text-4xl leading-tight font-bold tracking-[-0.66px] text-[#131313] sm:text-[44px] sm:leading-[54px]">
				{headline}
			</p>
			<p class="max-w-xl font-display text-[17px] leading-[28px] text-[#888785]">
				{subtext}
			</p>
		</div>

		<div class="flex w-full flex-col gap-16">
			{
				useCases.map((useCase) => (
					<div
						class:list={[
							"flex flex-col items-center gap-10 lg:flex-row lg:gap-16",
							useCase.reverse && "lg:flex-row-reverse",
						]}
					>
						<div
							class:list={[
								"h-[280px] w-full shrink-0 overflow-hidden sm:h-[360px] lg:h-100 lg:w-150",
								useCase.reverse
									? "rounded-tl-4xl rounded-tr-4xl rounded-br-4xl"
									: "rounded-tl-4xl rounded-tr-4xl rounded-bl-4xl",
							]}
						>
							<Image
								src={useCase.image}
								alt={useCase.imageAlt}
								class="h-full w-full object-cover"
								widths={[480, 768, 1100]}
								sizes="(min-width: 1024px) 600px, 100vw"
							/>
						</div>

						<div class="flex w-full flex-col items-start gap-6 lg:w-140">
							<div class="flex flex-col items-start gap-4">
								<div class="flex flex-wrap items-center gap-4">
									<p class="font-display text-3xl font-bold text-[#131313] sm:text-[32px]">
										{useCase.company}
									</p>
									<div class="flex items-center justify-center rounded-full border border-wale-700 px-4 py-2">
										<p class="font-display text-sm font-medium text-wale-700">
											{useCase.badge}
										</p>
									</div>
								</div>
								<p class="font-display text-[17px] leading-[28px] text-[#5f5f5f]">
									{useCase.description}
								</p>
							</div>

							<div class="rounded-tl-2xl rounded-tr-2xl rounded-bl-2xl bg-[#fff3e7] px-8 py-6">
								<p class="font-display text-xl leading-[32px] font-medium tracking-[-0.08px] text-wale-700">
									{useCase.outcome}
								</p>
							</div>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>
