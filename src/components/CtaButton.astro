---
interface Props {
	label: string;
	href?: string;
	as?: "a" | "span";
	variant?: "primary" | "maroon" | "cream" | "ghost" | "peach";
	shape?: "notch" | "full";
	radius?: "xl" | "2xl";
	size?: "md" | "nav";
	fullWidth?: boolean;
	class?: string;
}

const {
	label,
	href,
	as = "a",
	variant = "primary",
	shape = "notch",
	radius = "xl",
	size = "md",
	fullWidth = false,
	class: className,
} = Astro.props;

const variantClass: Record<NonNullable<Props["variant"]>, string> = {
	primary: "bg-wale-700 text-white",
	maroon: "border border-wale-peach/16 bg-wale-700 text-white",
	cream: "bg-wale-cream text-wale-700",
	ghost: "border border-wale-peach bg-wale-peach/16 text-white",
	peach: "bg-wale-peach text-wale-700",
};

const shapeClass =
	shape === "full"
		? radius === "2xl"
			? "rounded-2xl"
			: "rounded-xl"
		: radius === "2xl"
			? "rounded-bl-2xl rounded-tl-2xl rounded-tr-2xl"
			: "rounded-bl-xl rounded-tl-xl rounded-tr-xl";

const sizeClass =
	size === "nav"
		? "font-display text-[13px] font-medium tracking-[0.13px]"
		: "font-display text-sm font-medium tracking-[0.14px]";

const Tag = as;
---

<Tag
	{...as === "a" ? { href: href ?? `${import.meta.env.BASE_URL}contact` } : {}}
	class:list={[
		fullWidth ? "block w-full" : "inline-block",
		"px-6 py-3.5 text-center",
		shapeClass,
		sizeClass,
		variantClass[variant],
		className,
	]}
>
	{label}
</Tag>
