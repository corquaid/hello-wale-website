---
import { Image } from "astro:assets";
import hostsBg from "../assets/images/hosts-bg.jpg";

const benefits = [
	{
		icon: "💸",
		title: "0% rates",
		description: "Rates at 0% for the first free months.",
	},
	{
		icon: "🤝",
		title: "Co-create the platform with us",
		description: "Your feedback shapes the product.",
	},
	{
		icon: "⭐",
		title: "Featured listing everyone sees",
		description: "On our homepage, in our launch press.",
	},
];
---

<section class="relative isolate">
	<Image
		src={hostsBg}
		alt=""
		class="absolute inset-x-0 -top-16 -z-10 h-[calc(100%+4rem)] w-full object-cover object-[68%_top] sm:-top-24 sm:h-[calc(100%+6rem)] lg:-top-32 lg:h-[calc(100%+8rem)]"
		widths={[768, 1200, 1600]}
		sizes="100vw"
	/>

	<div class="mx-auto flex max-w-6xl flex-col gap-12 px-6 py-28 sm:px-10 sm:py-36 lg:flex-row lg:items-center lg:justify-between lg:px-20 lg:py-48">
		<div class="flex w-full flex-col items-start gap-6 rounded-3xl bg-white/85 p-6 backdrop-blur-sm lg:w-130">
			<p class="font-display text-[11px] tracking-[0.33px] text-wale-700 uppercase">
				For hosts
			</p>
			<p class="font-display text-4xl leading-tight font-bold tracking-[-0.66px] text-wale-700 sm:text-5xl lg:text-[44px] lg:leading-[54px]">
				Be one of the first
				<br />
				hosts in Poland.
			</p>
			<p class="max-w-lg font-display text-[17px] leading-[28px] text-[#5f5f5f]">
				We're partnering with a small group of founding hosts to shape what HelloWale
				becomes. Get in early, help us design it, and earn exclusive launch benefits for
				life.
			</p>
			<a
				href="/contact"
				class="rounded-bl-xl rounded-tl-xl rounded-tr-xl bg-wale-700 px-6 py-3.5 font-display text-sm font-medium tracking-[0.14px] text-white"
			>
				List your property - it's free
			</a>
		</div>

		<div class="flex w-full flex-col gap-4 lg:w-88">
			{
				benefits.map((benefit) => (
					<div class="flex items-center gap-4 rounded-xl bg-white p-5 shadow-sm">
						<div class="flex size-10 shrink-0 items-center justify-center text-lg">
							{benefit.icon}
						</div>
						<div class="flex flex-col items-start gap-0.5">
							<p class="font-display text-[15px] font-bold tracking-[-0.045px] text-[#131313]">
								{benefit.title}
							</p>
							<p class="font-display text-[13px] leading-[18px] text-[#888785]">
								{benefit.description}
							</p>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>
