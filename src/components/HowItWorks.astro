---
import stepReachOut from "../assets/images/step-reach-out.png";
import stepLearnAboutYou from "../assets/images/step-learn-about-you.png";
import stepPartnership from "../assets/images/step-partnership.png";
import stepForever from "../assets/images/step-forever.png";

const steps = [
	{
		number: "01",
		title: "You reach out",
		description: "Through this site, or by email. We respond within 48 hours.",
		icon: stepReachOut,
	},
	{
		number: "02",
		title: "We learn about you",
		description: "A short call to understand your team's needs or your property's offering.",
		icon: stepLearnAboutYou,
	},
	{
		number: "03",
		title: "The partnership",
		description: "Subscription tier, booking rates, founding benefits tailored to fit.",
		icon: stepPartnership,
	},
	{
		number: "04",
		title: "You're in. Forever.",
		description: "Founding partners stay founding partners. Locked-in pricing, lifetime.",
		icon: stepForever,
	},
] as const;
---

<section class="bg-wale-cream/50 px-6 py-20 sm:px-10 lg:px-20 lg:py-30">
	<div class="mx-auto flex max-w-6xl flex-col items-center gap-16">
		<div class="flex flex-col items-center gap-4 text-center">
			<p class="font-display text-[11px] font-semibold tracking-[0.33px] text-wale-700 uppercase">
				How it works
			</p>
			<p class="max-w-3xl font-display text-4xl leading-tight font-bold tracking-[-1.12px] text-black sm:text-5xl lg:text-[56px] lg:leading-16">
				From conversation to workation.
			</p>
			<p class="max-w-xl font-display text-[17px] leading-7 text-[#5f5f5f]">
				HelloWale is launching in 2026. Here's how partnership works right now — before
				the platform is live.
			</p>
		</div>

		<div class="w-full" data-slider>
			<div
				class="scrollbar-none -mr-6 flex w-full cursor-grab snap-x snap-mandatory gap-4 overflow-x-auto pb-4 select-none active:cursor-grabbing sm:-mr-10 lg:mr-0 lg:grid lg:cursor-auto lg:grid-cols-4 lg:snap-none lg:overflow-visible lg:pb-0 lg:active:cursor-auto"
				data-track
			>
				{
					steps.map((step) => (
						<div
							class="flex h-full w-[85%] shrink-0 snap-center flex-col justify-between gap-8 rounded-[20px] bg-white p-8 sm:w-[60%] lg:w-auto lg:shrink"
							data-slide
						>
							<p class="font-display text-4xl font-bold tracking-[-0.6px] text-wale-700">
								{step.number}
							</p>

							<img
								src={step.icon.src}
								alt=""
								class="h-28 w-auto self-center object-contain"
							/>

							<div class="flex flex-col items-start gap-4">
								<p class="font-display text-2xl font-bold tracking-[-0.078px] text-[#131313]">
									{step.title}
								</p>
								<p class="font-display text-[13px] leading-5 text-[#888785]">
									{step.description}
								</p>
							</div>
						</div>
					))
				}
			</div>

			<div class="mt-2 flex justify-center gap-2 lg:hidden">
				{
					steps.map((_, index) => (
						<button
							type="button"
							aria-label={`Go to slide ${index + 1}`}
							data-dot={index}
							class="h-2 w-2 rounded-full bg-wale-700/25 transition-all data-[active=true]:w-6 data-[active=true]:bg-wale-700"
						/>
					))
				}
			</div>
		</div>

		<a
			href={`${import.meta.env.BASE_URL}contact`}
			class="rounded-bl-2xl rounded-tl-2xl rounded-tr-2xl bg-wale-700 px-6 py-3 font-display text-sm font-medium text-white"
		>
			Let's Talk
		</a>
	</div>
</section>
