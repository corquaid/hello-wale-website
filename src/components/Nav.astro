---
import { getRelativeLocaleUrl } from "astro:i18n";
import logoLight from "../assets/images/logo-mark-light.svg";
import logoDark from "../assets/images/logo-mark-dark.svg";
import CtaButton from "./CtaButton.astro";
import {
	useTranslations,
	translatedRoutes,
	locales,
	localeMeta,
	type Locale,
} from "../i18n/utils";

interface Props {
	variant?: "solid" | "transparent";
	lang?: Locale;
	currentPath?: string;
}

const { variant = "solid", lang = "en", currentPath = "" } = Astro.props;
const isTransparent = variant === "transparent";
const base = import.meta.env.BASE_URL;
const t = useTranslations(lang);

const homeHref = getRelativeLocaleUrl(lang, "");

const leftLinks = [
	{ href: getRelativeLocaleUrl(lang, "companies"), label: t.nav.forCompanies },
	{ href: getRelativeLocaleUrl(lang, "hosts"), label: t.nav.forHosts },
];

const rightLinks = [
	{ href: "#", label: t.nav.story },
	{ href: `${base}blog`, label: t.nav.blog },
	{ href: `${base}faq`, label: t.nav.faq },
];

const linkClass = isTransparent
	? "font-display text-[13px] font-medium text-white"
	: "font-display text-[13px] font-medium text-gray-700 hover:text-wale-700";

// Falls back to each locale's homepage when the current page has no
// translation yet, so the switcher never links to a 404.
const isCurrentPathTranslated = translatedRoutes.includes(currentPath);
const getLocaleHref = (loc: Locale) =>
	getRelativeLocaleUrl(loc, isCurrentPathTranslated ? currentPath : "");

const langToggleClass = isTransparent
	? "flex items-center gap-1.5 rounded-full px-3 py-2 font-display text-[13px] font-medium text-white/80 transition-colors hover:bg-white/10 hover:text-white"
	: "flex items-center gap-1.5 rounded-full px-3 py-2 font-display text-[13px] font-medium text-gray-500 transition-colors hover:bg-gray-50 hover:text-wale-700";
---

<header
	class={
		isTransparent
			? "relative z-10 py-6"
			: "relative z-10 border-b border-gray-200 bg-white px-6 py-4 lg:px-20"
	}
>
	<div class="mx-auto hidden max-w-7xl items-center justify-between lg:flex">
		<nav class="flex flex-1 items-center gap-8">
			{leftLinks.map((link) => <a href={link.href} class={linkClass}>{link.label}</a>)}
		</nav>

		<a href={homeHref} class="flex shrink-0 items-center">
			<img
				src={isTransparent ? logoLight.src : logoDark.src}
				alt="hellowale"
				class="aspect-298/34 h-8.5 w-auto max-w-none"
			/>
		</a>

		<div class="flex flex-1 items-center justify-end gap-6">
			{rightLinks.map((link) => <a href={link.href} class={linkClass}>{link.label}</a>)}
			<div class="relative" data-lang-switcher>
				<button
					type="button"
					data-lang-toggle
					aria-expanded="false"
					aria-haspopup="true"
					aria-label="Change language"
					class={langToggleClass}
				>
					<span aria-hidden="true">{localeMeta[lang].flag}</span>
					<span>{lang.toUpperCase()}</span>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="h-3.5 w-3.5"
					>
						<path d="m6 9 6 6 6-6" />
					</svg>
				</button>
				<div
					data-lang-menu
					class="pointer-events-none absolute right-0 top-full z-20 mt-2 w-40 origin-top-right scale-95 rounded-xl border border-gray-100 bg-white p-1.5 opacity-0 shadow-lg transition-all duration-150"
				>
					{
						locales.map((loc) => (
							<a
								href={getLocaleHref(loc)}
								class:list={[
									"flex items-center gap-2 rounded-lg px-3 py-2 font-display text-[13px] font-medium",
									loc === lang
										? "bg-wale-sand text-wale-700"
										: "text-gray-600 hover:bg-gray-50",
								]}
							>
								<span aria-hidden="true">{localeMeta[loc].flag}</span>
								{localeMeta[loc].label}
							</a>
						))
					}
				</div>
			</div>
			<CtaButton
				label={t.nav.partnerWithUs}
				href={`${base}contact`}
				variant={isTransparent ? "cream" : "primary"}
				size="nav"
				class={isTransparent ? "" : "hover:bg-wale-800"}
			/>
		</div>
	</div>

	<div class="relative mx-auto flex max-w-7xl items-center lg:hidden">
		<button
			type="button"
			data-nav-toggle
			aria-expanded="false"
			aria-controls="mobile-nav-drawer"
			aria-label="Open menu"
			class="relative z-10"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				class={isTransparent ? "h-6 w-6 text-white" : "h-6 w-6 text-gray-700"}
			>
				<path d="M4 6h16M4 12h16M4 18h16" />
			</svg>
		</button>

		<a href={homeHref} class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
			<img
				src={isTransparent ? logoLight.src : logoDark.src}
				alt="hellowale"
				class="aspect-298/34 h-6 w-auto max-w-none"
			/>
		</a>
	</div>
</header>

<div
	id="mobile-nav-drawer"
	class="pointer-events-none fixed inset-0 z-50 lg:hidden"
	data-nav-drawer
>
	<div
		data-nav-backdrop
		class="absolute inset-0 bg-black/50 opacity-0 pointer-events-none transition-opacity duration-300"
	>
	</div>
	<div
		data-nav-panel
		class="pointer-events-auto absolute inset-y-0 left-0 w-96 max-w-[90vw] -translate-x-full bg-white p-6 shadow-xl transition-transform duration-300"
	>
		<div class="relative flex items-center justify-center">
			<img src={logoDark.src} alt="hellowale" class="aspect-298/34 h-6 w-auto max-w-none" />
			<button type="button" data-nav-close aria-label="Close menu" class="absolute right-0">
				<svg
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					class="h-6 w-6 text-gray-700"
				>
					<path d="M6 6l12 12M18 6L6 18" />
				</svg>
			</button>
		</div>

		<nav class="mt-8 flex flex-col gap-5">
			{
				[...leftLinks, ...rightLinks].map((link) => (
					<a
						href={link.href}
						class="font-display text-[15px] font-medium text-gray-700 hover:text-wale-700"
					>
						{link.label}
					</a>
				))
			}
		</nav>

		<div class="mt-6 flex items-center gap-2">
			{
				locales.map((loc) => (
					<a
						href={getLocaleHref(loc)}
						class:list={[
							"flex items-center gap-1.5 rounded-full border px-3 py-1.5 font-display text-[13px] font-medium",
							loc === lang
								? "border-wale-700 bg-wale-sand text-wale-700"
								: "border-gray-200 text-gray-500",
						]}
					>
						<span aria-hidden="true">{localeMeta[loc].flag}</span>
						{loc.toUpperCase()}
					</a>
				))
			}
		</div>

		<CtaButton
			label={t.nav.partnerWithUs}
			href={`${base}contact`}
			size="nav"
			fullWidth
			class="mt-8"
		/>
	</div>
</div>

<script>
	function closeDrawer() {
		const backdrop = document.querySelector("[data-nav-backdrop]");
		const panel = document.querySelector("[data-nav-panel]");
		const toggle = document.querySelector("[data-nav-toggle]");
		backdrop?.classList.add("opacity-0", "pointer-events-none");
		panel?.classList.add("-translate-x-full");
		toggle?.setAttribute("aria-expanded", "false");
		document.body.classList.remove("overflow-hidden");
	}

	function openDrawer() {
		const backdrop = document.querySelector("[data-nav-backdrop]");
		const panel = document.querySelector("[data-nav-panel]");
		const toggle = document.querySelector("[data-nav-toggle]");
		backdrop?.classList.remove("opacity-0", "pointer-events-none");
		panel?.classList.remove("-translate-x-full");
		toggle?.setAttribute("aria-expanded", "true");
		document.body.classList.add("overflow-hidden");
	}

	document.querySelector("[data-nav-toggle]")?.addEventListener("click", openDrawer);
	document.querySelector("[data-nav-close]")?.addEventListener("click", closeDrawer);
	document.querySelector("[data-nav-backdrop]")?.addEventListener("click", closeDrawer);

	const langToggle = document.querySelector("[data-lang-toggle]");
	const langMenu = document.querySelector("[data-lang-menu]");

	function closeLangMenu() {
		langMenu?.classList.add("opacity-0", "scale-95", "pointer-events-none");
		langToggle?.setAttribute("aria-expanded", "false");
	}

	function toggleLangMenu(event: Event) {
		event.stopPropagation();
		const isOpen = langToggle?.getAttribute("aria-expanded") === "true";
		if (isOpen) {
			closeLangMenu();
		} else {
			langMenu?.classList.remove("opacity-0", "scale-95", "pointer-events-none");
			langToggle?.setAttribute("aria-expanded", "true");
		}
	}

	langToggle?.addEventListener("click", toggleLangMenu);
	document.addEventListener("click", closeLangMenu);
</script>
