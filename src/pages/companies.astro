---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import HowItWorks from "../components/HowItWorks.astro";
import ForCompanies from "../components/ForCompanies.astro";
import WhyWellbeing from "../components/WhyWellbeing.astro";
import UseCases from "../components/UseCases.astro";
import ScienceOfChange from "../components/ScienceOfChange.astro";
import usecaseMarketing from "../assets/images/usecase-marketing.jpg";
import usecaseTechteam from "../assets/images/usecase-techteam.jpg";

const useCases = [
	{
		company: "Marketing agency",
		badge: "25 employees",
		description: "Quarterly team workations to reset and brainstorm next campaigns.",
		outcome: "Three campaigns. One villa in Tuscany. Zero meeting fatigue.",
		image: usecaseMarketing,
		imageAlt: "Two colleagues from a marketing agency looking at a laptop together outdoors",
		reverse: false,
	},
	{
		company: "Tech scale-up",
		badge: "100 + employees",
		description:
			"Each team member gets 2 workation weeks per year as part of their wellbeing package.",
		outcome: "A retention story we tell at every job interview.",
		image: usecaseTechteam,
		imageAlt: "A tech team collaborating around a table with coffee and notes",
		reverse: true,
	},
];
---

<Layout
	title="For Companies"
	description="Give your team a wellbeing benefit they'll actually use — workation partnerships with HelloWale."
	showNav={false}
>
	<Hero
		beforeText="Out of"
		afterText="not out of ambition"
		subtext="Built for companies, hosts, and remote professionals"
		showPhoto={false}
		ctas={[
			{ label: "Start a workation", variant: "maroon" },
			{ label: "Start hosting", variant: "peach" },
		]}
	/>
	<HowItWorks
		headline="Become a founding partner"
		subtext="HelloWale is launching later in 2026. Here's how partnership works right now before the platform is open to everyone."
	/>
	<section class="bg-white px-6 py-16 text-center sm:py-20">
		<p class="font-display text-3xl font-bold tracking-[-0.96px] text-wale-700 sm:text-4xl lg:text-5xl">
			The bigger picture
		</p>
	</section>
	<ForCompanies />
	<WhyWellbeing />
	<UseCases useCases={useCases} />
	<ScienceOfChange />
</Layout>
