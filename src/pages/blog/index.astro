---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title="Blog" description="Latest posts.">
	<section class="mx-auto max-w-3xl px-6 py-16">
		<h1 class="text-3xl font-bold text-slate-900 sm:text-4xl">Blog</h1>

		<div class="mt-10 divide-y divide-slate-200">
			{
				posts.map((post) => (
					<article class="py-6">
						<a href={`/blog/${post.id}`} class="text-xl font-semibold text-slate-900 hover:text-indigo-600">
							{post.data.title}
						</a>
						<p class="mt-1 text-sm text-slate-500">
							{post.data.pubDate.toLocaleDateString("en-US", {
								year: "numeric",
								month: "long",
								day: "numeric",
							})}
						</p>
						<p class="mt-2 text-slate-600">{post.data.description}</p>
					</article>
				))
			}
		</div>
	</section>
</Layout>
