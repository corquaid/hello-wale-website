---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.tsx";
---

<Layout title="Contact" description="Get in touch.">
	<section class="mx-auto max-w-lg px-6 py-16">
		<h1 class="text-3xl font-bold text-slate-900 sm:text-4xl">Contact us</h1>
		<p class="mt-3 text-slate-600">Have a question? Send us a message below.</p>

		<div class="mt-10">
			<ContactForm client:load />
		</div>
	</section>
</Layout>
